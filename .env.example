# Required environment variables for production deployment

# PostgreSQL connection string (provided automatically by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-string

# Node environment (set to "production" on Railway)
NODE_ENV=production

# Port for the HTTP server. Railway sets this automatically.
PORT=8080
